rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /replays/{replayId} {
      // Anyone can read a shared replay.
      allow read: if true;

      // Anyone can upload, but:
      //  - the doc may only contain the listed keys (bytes/upload meta plus
      //    optional summary fields denormalized for the recent-replays list)
      //  - bytes must be under 1 MiB (well under Firestore's 1,048,576-byte
      //    document hard limit) so the rest of the doc fits the limit too
      allow create: if request.resource.data.keys().hasOnly([
                       'bytes', 'uploadedAt', 'fileName',
                       'player', 'map', 'recordedAt', 'durationMs',
                       'totalDamage', 'avgDps', 'damageEvents', 'kills',
                       'entitiesSeen', 'handledPackets', 'packetCount'
                     ])
                    && request.resource.data.bytes is bytes
                    && request.resource.data.bytes.size() < 1024 * 1024
                    && request.resource.data.fileName is string
                    && request.resource.data.fileName.size() < 200;

      // Replays are immutable and never expire by user action.
      allow update, delete: if false;
    }

    match /suggestions/{suggestionId} {
      // Anyone can read the suggestion list.
      allow read: if true;

      // Anyone can post a suggestion, but:
      //  - the doc must contain exactly the listed keys
      //  - text must be a non-empty string under 500 chars
      //  - vote counters must start at 0
      //  - createdAt must be the server timestamp (request time)
      allow create: if request.resource.data.keys().hasOnly([
                       'text', 'createdAt', 'upvotes', 'downvotes'
                     ])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.upvotes == 0
                    && request.resource.data.downvotes == 0
                    && request.resource.data.createdAt == request.time;

      // Updates may only bump exactly one of upvotes/downvotes by +1; the
      // text and createdAt fields are immutable. Cookie-based dedup on the
      // client prevents repeat voting; the rule just caps the damage if
      // someone tries to script it.
      allow update: if request.resource.data.keys().hasOnly([
                       'text', 'createdAt', 'upvotes', 'downvotes'
                     ])
                    && request.resource.data.text == resource.data.text
                    && request.resource.data.createdAt == resource.data.createdAt
                    && (
                         (request.resource.data.upvotes == resource.data.upvotes + 1
                          && request.resource.data.downvotes == resource.data.downvotes)
                         ||
                         (request.resource.data.downvotes == resource.data.downvotes + 1
                          && request.resource.data.upvotes == resource.data.upvotes)
                       );

      allow delete: if false;
    }
  }
}
